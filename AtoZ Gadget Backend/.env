# ========================
# CORE APPLICATION
# ========================
DATABASE_URL=mysql+pymysql://root:@localhost:3306/atoz_gadgets_db
APP_NAME=AtoZ Gadgets API
APP_ENV=development
DEBUG=True
SECRET_KEY=deodap_secret_key_2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ========================
# REDIS
# ========================
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_TTL=300

# ========================
# RAZORPAY PAYMENT GATEWAY
# ========================
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_SECRET
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET
RAZORPAY_CURRENCY=INR

# ========================
# STRIPE (OPTIONAL)
# ========================
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_SECRET

# ========================
# ELASTICSEARCH
# ========================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PRODUCTS=atoz_products
ELASTICSEARCH_INDEX_CATEGORIES=atoz_categories
ELASTICSEARCH_INDEX_BRANDS=atoz_brands

# ========================
# EMAIL (SMTP)
# ========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@deodap.com

# ========================
# AWS S3 / MEDIA
# ========================
AWS_ACCESS_KEY_ID=REPLACE_WITH_YOUR_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_SECRET
AWS_S3_BUCKET=atoz-media
AWS_S3_REGION=ap-south-1
CDN_BASE_URL=https://cdn.atozgadgets.com
MEDIA_STORAGE=local

# ========================
# PROMETHEUS MONITORING
# ========================
ENABLE_METRICS=True
METRICS_PATH=/metrics

# ========================
# SECURITY
# ========================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_PER_MINUTE=100
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_LOCKOUT_MINUTES=15
BLOCKED_IPS=

# ========================
# GATEWAY
# ========================
GATEWAY_PORT=8080
BACKEND_URL=http://localhost:8000