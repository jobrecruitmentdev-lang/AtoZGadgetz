{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Expected project directory matrix map",
  "type": "object",
  "required": [
    "app",
    "lib",
    "components"
  ],
  "properties": {
    "app": {
      "type": "object",
      "description": "Next.js App Router directories"
    },
    "lib": {
      "type": "object",
      "description": "Shared utility functions and API clients"
    },
    "components": {
      "type": "object",
      "description": "Reusable React components"
    }
  }
}
